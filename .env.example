# Copy to .env and fill in real values. .env is git-ignored — never commit it.

# SQL Server SA password (min 8 chars, 3 of: upper/lower/digit/symbol)
MSSQL_SA_PASSWORD=ChangeMe_Str0ng!

# Full connection string used by the API (references the compose 'db' service)
EMS_DB_CONNECTION=Server=db;Database=EmployeeManagementSys;User Id=sa;Password=ChangeMe_Str0ng!;TrustServerCertificate=True

# --- Prefer your LOCAL SQL Server instead of the containerized one? ---
# Point the connection at the host and start only api+web (skips the db container):
#   EMS_DB_CONNECTION=Server=host.docker.internal;Database=EmployeeManagementSys;Trusted_Connection=False;User Id=<user>;Password=<pw>;TrustServerCertificate=True
#   docker compose up --no-deps api web
# (Enable TCP/IP on your local SQL instance. See docs/agdr/AgDR-0001-local-deployment-and-migrations.md)

# JWT settings (IssuerSigningKey: use a random string of 32+ characters)
JWT_ISSUER=http://localhost:8085
JWT_AUDIENCE=http://localhost:8085
JWT_SIGNING_KEY=change-me-to-a-random-32-plus-character-secret

# Build context of the Angular client's sibling clone (default matches the GitHub clone name)
NG_BUILD_CONTEXT=../Employee-Management-System-ng
